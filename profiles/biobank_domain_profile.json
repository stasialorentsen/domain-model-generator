{
  "domain": "biobank",
  "description": "Domain profile for biodata datasets stored in freezers, organized under research projects.",

  "class_mappings": {
    "Subject": "ResearchProject",
    "Resource": "BiodataDataset",
    "Repository": "Freezer",
    "ProcessEvent": "DatasetLifecycleEvent",
    "AccessLogEntry": "RepositoryAccessLog"
  },

  "attribute_mappings": {
    "Subject.subjectId": "projectId",
    "Subject.name": "projectName",
    "Subject.subjectType": "projectType",
    "Subject.primaryIdentifier": "projectCode",

    "Resource.resourceId": "datasetId",
    "Resource.resourceType": "datasetType",
    "Resource.domain": "researchDomain",
    "Resource.owner": "dataOwnerUnit",
    "Resource.lifecycleStage": "datasetLifecycleStage",

    "Repository.repositoryId": "freezerId",
    "Repository.repositoryType": "freezerType",
    "Repository.location": "location",
    "Repository.managedBy": "managedBy",

    "ProcessEvent.processId": "eventId",
    "ProcessEvent.processType": "eventType",
    "ProcessEvent.lifecycleStage": "lifecycleStage",
    "ProcessEvent.responsibleUnit": "responsibleUnit",

    "AccessLogEntry.logId": "accessLogId",
    "AccessLogEntry.action": "action",
    "AccessLogEntry.resourceRef": "datasetRef"
  },

  "required": {
    "ResearchProject": [
      "projectId",
      "projectName"
    ],
    "BiodataDataset": [
      "datasetId",
      "datasetType",
      "dataOwnerUnit",
      "datasetLifecycleStage"
    ],
    "Freezer": [
      "freezerId",
      "location"
    ],
    "RepositoryAccessLog": [
      "accessLogId",
      "timestamp",
      "action",
      "datasetRef"
    ]
  },

  "additional_attributes": {
    "BiodataDataset": [
      {
        "name": "projectRef",
        "type": "string"
      },
      {
        "name": "containsSensitiveData",
        "type": "boolean"
      },
      {
        "name": "recordCount",
        "type": "integer"
      }
    ],
    "Freezer": [
      {
        "name": "targetTemperatureC",
        "type": "number"
      },
      {
        "name": "backupPower",
        "type": "boolean"
      }
    ],
    "RepositoryAccessLog": [
      {
        "name": "cardReaderId",
        "type": "string"
      }
    ]
  }
}
