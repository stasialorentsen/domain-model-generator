{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/domain.schema.json",
  "title": "Domain Schema",
  "type": "object",
  "$defs": {
    "Subject": {
      "type": "object",
      "properties": {
        "subjectId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "subjectType": {
          "type": "string"
        },
        "primaryIdentifier": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Resource": {
      "type": "object",
      "properties": {
        "resourceId": {
          "type": "string"
        },
        "resourceType": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "lifecycleStage": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "MetadataCommon": {
      "type": "object",
      "properties": {
        "purpose": {
          "type": "string"
        },
        "classificationLevel": {
          "type": "string"
        },
        "lawfulBasisRef": {
          "type": "string"
        },
        "retentionPolicyRef": {
          "type": "string"
        },
        "securityLevel": {
          "type": "string"
        },
        "criticality": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Storage": {
      "type": "object",
      "properties": {
        "storageId": {
          "type": "string"
        },
        "storageType": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "managedBy": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ProcessEvent": {
      "type": "object",
      "properties": {
        "processId": {
          "type": "string"
        },
        "processType": {
          "type": "string"
        },
        "lifecycleStage": {
          "type": "string"
        },
        "responsibleUnit": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "AccessLogEntry": {
      "type": "object",
      "properties": {
        "logId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "action": {
          "type": "string"
        },
        "resourceRef": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "PolicyConstraint": {
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string"
        },
        "ruleType": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
