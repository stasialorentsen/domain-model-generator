{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/person.schema.json",
  "title": "Person Domain Schema",
  "type": "object",
  "$defs": {
    "Person": {
      "type": "object",
      "properties": {
        "personId": {
          "type": "string"
        },
        "fullName": {
          "type": "string"
        },
        "subjectType": {
          "type": "string"
        },
        "primaryIdentifier": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "department": {
          "type": "string"
        },
        "related_to": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Resource"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "personId",
        "fullName"
      ]
    },
    "Resource": {
      "type": "object",
      "properties": {
        "resourceId": {
          "type": "string"
        },
        "resourceType": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "lifecycleStage": {
          "type": "string"
        },
        "classified_by": {
          "$ref": "#/$defs/MetadataCommon"
        },
        "stored_in": {
          "$ref": "#/$defs/Repository"
        }
      },
      "additionalProperties": false,
      "required": [
        "classified_by",
        "stored_in"
      ]
    },
    "MetadataCommon": {
      "type": "object",
      "properties": {
        "purpose": {
          "type": "string"
        },
        "classificationLevel": {
          "type": "string"
        },
        "lawfulBasisRef": {
          "type": "string"
        },
        "retentionPolicyRef": {
          "type": "string"
        },
        "securityLevel": {
          "type": "string"
        },
        "criticality": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Repository": {
      "type": "object",
      "properties": {
        "repositoryId": {
          "type": "string"
        },
        "repositoryType": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "managedBy": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "ProcessEvent": {
      "type": "object",
      "properties": {
        "processId": {
          "type": "string"
        },
        "processType": {
          "type": "string"
        },
        "lifecycleStage": {
          "type": "string"
        },
        "responsibleUnit": {
          "type": "string"
        },
        "acts_on": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Resource"
          }
        }
      },
      "additionalProperties": false
    },
    "AccessLogEntry": {
      "type": "object",
      "properties": {
        "logId": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "action": {
          "type": "string"
        },
        "resourceRef": {
          "type": "string"
        },
        "by_subject": {
          "$ref": "#/$defs/Person"
        },
        "targets_resource": {
          "$ref": "#/$defs/Resource"
        },
        "targets_repository": {
          "$ref": "#/$defs/Repository"
        }
      },
      "additionalProperties": false,
      "required": [
        "by_subject"
      ]
    },
    "PolicyConstraint": {
      "type": "object",
      "properties": {
        "ruleId": {
          "type": "string"
        },
        "ruleType": {
          "type": "string"
        },
        "reference": {
          "type": "string"
        },
        "applies_to": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MetadataCommon"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
